{
  "name": "@lanedeck/center-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "format": "prettier --check . --ignore-path ../../.prettierignore",
    "check:cloudflare": "bash ../../scripts/cloudflare-center-ci.sh",
    "preflight": "bash ../../scripts/cloudflare-center-preflight.sh",
    "deploy": "bash ../../scripts/cloudflare-center-deploy.sh",
    "deploy:raw": "wrangler deploy --keep-vars",
    "deploy:dry-run": "LANEDECK_AGENT_TOKEN=dry-run-agent-token LANEDECK_AI_MUTATION_TOKEN=dry-run-ai-mutation-token LANEDECK_READ_TOKEN=dry-run-read-token wrangler deploy --dry-run --strict --outdir .wrangler-dry-run"
  },
  "dependencies": {
    "@lanedeck/protocol": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
