{
  "name": "lanedeck",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "build": "corepack pnpm -r build && cargo build --workspace",
    "check": "corepack pnpm -r check && cargo check --workspace",
    "check:e2e": "tsc -p e2e/tsconfig.json --noEmit",
    "test": "corepack pnpm -r test && cargo test --workspace",
    "test:e2e": "bash scripts/e2e.sh",
    "lint": "corepack pnpm -r lint && cargo clippy --workspace --all-targets -- -D warnings",
    "format": "corepack pnpm -r format && cargo fmt --all",
    "ci": "corepack pnpm run check && corepack pnpm run test && corepack pnpm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
